# idea-code 环境配置
# 复制此文件为 .env 并填入实际值

# ============================================================
# Builder 配置（主 agent）
# ============================================================
IDEA_API_KEY=sk-ant-xxx
IDEA_BASE_URL=https://api.anthropic.com
IDEA_MODEL=claude-sonnet-4-6
IDEA_MAX_TOKENS=8000
# IDEA_BUILDER_MAX_TOKENS=32000   # Builder 独立配置（默认 32000，覆盖 IDEA_MAX_TOKENS）

# ============================================================
# Reviewer A 配置（独立模型，技术/严谨视角）
# ============================================================
REV_A_API_KEY=sk-ant-xxx
REV_A_BASE_URL=https://api.anthropic.com
REV_A_MODEL=claude-sonnet-4-6
REV_A_MAX_TOKENS=8000

# ============================================================
# Reviewer B 配置（独立模型，产品/价值视角）
# ============================================================
REV_B_API_KEY=sk-ant-xxx
REV_B_BASE_URL=https://api.anthropic.com
REV_B_MODEL=claude-sonnet-4-6
REV_B_MAX_TOKENS=8000

# ============================================================
# 全局配置
# ============================================================
IDEA_MAX_ROUNDS=10

# ============================================================
# Web 搜索配置
# 后端选择: SEARCH_PROVIDER=bigmodel (默认) | minimax (需 npm install -g mmx-cli)
# ============================================================
SEARCH_PROVIDER=bigmodel
BIGMODEL_API_KEY=your-bigmodel-api-key
# MINIMAX_API_KEY=your-minimax-api-key  # minimax 后端需 mmx-cli

# ============================================================
# 兼容 Anthropic 协议的后端（参考）
# 
# Provider   Base URL
# ─────────  ──────────────────────────────────
# Anthropic  https://api.anthropic.com
# MiniMax    https://api.minimaxi.com/anthropic
# GLM        https://open.bigmodel.cn/api/anthropic
# Kimi       https://api.moonshot.cn/anthropic
# DeepSeek   https://api.deepseek.com/anthropic
# ============================================================
